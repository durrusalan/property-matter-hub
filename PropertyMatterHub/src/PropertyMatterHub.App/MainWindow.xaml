<ui:FluentWindow x:Class="PropertyMatterHub.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:PropertyMatterHub.App.ViewModels"
        xmlns:views="clr-namespace:PropertyMatterHub.App.Views"
        Title="Property Matter Hub"
        MinWidth="1100" MinHeight="700"
        Width="1300" Height="800"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ── Sidebar ─────────────────────────────────────────────────── -->
    <Border Grid.Column="0" Background="{ui:ThemeResource ApplicationBackgroundBrush}"
            BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}" BorderThickness="0,0,1,0">
      <DockPanel>

        <!-- Logo -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,20,16,24">
          <Border Width="36" Height="36" CornerRadius="10"
                  Background="{ui:ThemeResource SystemAccentColorPrimaryBrush}">
            <ui:SymbolIcon Symbol="Briefcase24" Foreground="White" FontSize="18" />
          </Border>
          <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="Property Matter" FontWeight="SemiBold" FontSize="13" />
            <TextBlock Text="Hub" FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
          </StackPanel>
        </StackPanel>

        <!-- Search bar -->
        <Border DockPanel.Dock="Top" Margin="12,0,12,12">
          <ui:TextBox x:Name="SearchBox"
                      PlaceholderText="Search matters, clients…"
                      Icon="{ui:SymbolIcon Symbol=Search24}"
                      Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
        </Border>

        <!-- Nav items -->
        <ui:NavigationView DockPanel.Dock="Top"
                           PaneDisplayMode="LeftMinimal"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False">
          <ui:NavigationView.MenuItems>
            <ui:NavigationViewItem Content="Dashboard"  Tag="Dashboard"  Icon="{ui:SymbolIcon Symbol=Home24}"        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavigationPage.Dashboard}" />
            <ui:NavigationViewItem Content="Matters"    Tag="Matters"    Icon="{ui:SymbolIcon Symbol=Briefcase24}"   Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavigationPage.Matters}" />
            <ui:NavigationViewItem Content="Clients"    Tag="Clients"    Icon="{ui:SymbolIcon Symbol=People24}"      Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavigationPage.Clients}" />
            <ui:NavigationViewItem Content="Emails"     Tag="Emails"     Icon="{ui:SymbolIcon Symbol=Mail24}"        Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavigationPage.Emails}" />
            <ui:NavigationViewItem Content="Calendar"   Tag="Calendar"   Icon="{ui:SymbolIcon Symbol=Calendar24}"    Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavigationPage.Calendar}" />
          </ui:NavigationView.MenuItems>
          <ui:NavigationView.FooterMenuItems>
            <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Symbol=Settings24}"
                                   Command="{Binding NavigateCommand}" CommandParameter="{x:Static vm:NavigationPage.Settings}" />
          </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

      </DockPanel>
    </Border>

    <!-- ── Main content area ──────────────────────────────────────── -->
    <Grid Grid.Column="1">

      <!-- Title bar -->
      <ui:TitleBar DockPanel.Dock="Top" Title="Property Matter Hub"
                   ShowMinimize="True" ShowMaximize="True" ShowClose="True" />

      <!-- Page switcher -->
      <ContentControl Margin="0,32,0,0">
        <ContentControl.Style>
          <Style TargetType="ContentControl">
            <Style.Triggers>
              <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:NavigationPage.Dashboard}">
                <Setter Property="Content" Value="{Binding Dashboard}" />
                <Setter Property="ContentTemplate">
                  <Setter.Value><DataTemplate><views:DashboardView /></DataTemplate></Setter.Value>
                </Setter>
              </DataTrigger>
              <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:NavigationPage.Matters}">
                <Setter Property="Content" Value="{Binding}" />
                <Setter Property="ContentTemplate">
                  <Setter.Value><DataTemplate><views:MattersView /></DataTemplate></Setter.Value>
                </Setter>
              </DataTrigger>
              <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:NavigationPage.Clients}">
                <Setter Property="Content" Value="{Binding ClientList}" />
                <Setter Property="ContentTemplate">
                  <Setter.Value><DataTemplate><views:ClientsView /></DataTemplate></Setter.Value>
                </Setter>
              </DataTrigger>
              <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:NavigationPage.Emails}">
                <Setter Property="Content" Value="{Binding Email}" />
                <Setter Property="ContentTemplate">
                  <Setter.Value><DataTemplate><views:EmailView /></DataTemplate></Setter.Value>
                </Setter>
              </DataTrigger>
              <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:NavigationPage.Calendar}">
                <Setter Property="Content" Value="{Binding Calendar}" />
                <Setter Property="ContentTemplate">
                  <Setter.Value><DataTemplate><views:CalendarView /></DataTemplate></Setter.Value>
                </Setter>
              </DataTrigger>
              <DataTrigger Binding="{Binding CurrentPage}" Value="{x:Static vm:NavigationPage.Settings}">
                <Setter Property="Content" Value="{Binding Settings}" />
                <Setter Property="ContentTemplate">
                  <Setter.Value><DataTemplate><views:SettingsView /></DataTemplate></Setter.Value>
                </Setter>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </ContentControl.Style>
      </ContentControl>

    </Grid>
  </Grid>
</ui:FluentWindow>
