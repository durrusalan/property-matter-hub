<UserControl x:Class="PropertyMatterHub.App.Views.MattersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:PropertyMatterHub.App.ViewModels">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="340" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- ── Matter list panel ──────────────────────────────────────── -->
    <Border Grid.Column="0" BorderBrush="{ui:ThemeResource ControlElevationBorderBrush}" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8">
          <TextBlock Text="Matters" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="Active only" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ui:ToggleSwitch IsChecked="{Binding MatterList.ShowActiveOnly}" />
          </StackPanel>
        </StackPanel>

        <ui:ProgressRing DockPanel.Dock="Top" IsIndeterminate="True" Margin="16"
                         Visibility="{Binding MatterList.IsLoading, Converter={StaticResource BoolToVisibility}}" />

        <ListBox ItemsSource="{Binding MatterList.Matters}"
                 SelectedItem="{Binding MatterList.SelectedMatter}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 BorderThickness="0"
                 Background="Transparent">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Padding" Value="12,10" />
              <Setter Property="Margin" Value="8,2" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <Border CornerRadius="8" Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                      <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{ui:ThemeResource ControlFillColorSecondaryBrush}" />
                      </Trigger>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                  <ui:Badge Content="{Binding MatterRef}" Margin="0,0,8,0" />
                  <TextBlock Text="{Binding Status}" FontSize="11"
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Client.Name}" FontSize="12"
                           Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- ── Matter detail panel ────────────────────────────────────── -->
    <ContentControl Grid.Column="1" DataContext="{Binding MatterDetail}">
      <ContentControl.Style>
        <Style TargetType="ContentControl"
               xmlns:views2="clr-namespace:PropertyMatterHub.App.Views">
          <Setter Property="Content">
            <Setter.Value><views2:MatterDetailView /></Setter.Value>
          </Setter>
          <Style.Triggers>
            <DataTrigger Binding="{Binding SelectedMatter}" Value="{x:Null}">
              <Setter Property="Content">
                <Setter.Value>
                  <TextBlock Text="Select a matter to view details"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" FontSize="14" />
                </Setter.Value>
              </Setter>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </ContentControl.Style>
    </ContentControl>

  </Grid>
</UserControl>
