<Window x:Class="PropertyMatterHub.App.Views.GoogleCredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Connect Google Account"
        Width="520" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}">

  <Grid Margin="32,28,32,28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,24">
      <TextBlock Text="Connect Google Account" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8" />
      <TextBlock TextWrapping="Wrap" FontSize="13"
                 Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
        Enter your Google OAuth 2.0 credentials. These are the <Bold>Client ID</Bold> and
        <Bold>Client Secret</Bold> from your Google Cloud Console project.
        Once entered, a browser window will open to authorise your Google account.
      </TextBlock>
    </StackPanel>

    <!-- Fields -->
    <StackPanel Grid.Row="1" VerticalAlignment="Top">

      <!-- Step 1 hint -->
      <Border Padding="12,10" CornerRadius="8" Margin="0,0,0,16"
              Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
        <StackPanel>
          <TextBlock Text="How to get your credentials:" FontWeight="SemiBold" Margin="0,0,0,6" FontSize="12" />
          <TextBlock FontSize="12" TextWrapping="Wrap"
                     Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
            1. Go to console.cloud.google.com → APIs &amp; Services → Credentials
            <LineBreak />2. Create or select an OAuth 2.0 Client ID (Desktop app type)
            <LineBreak />3. Copy the Client ID and Client Secret below
          </TextBlock>
          <TextBlock Margin="0,6,0,0" FontSize="12">
            <Hyperlink NavigateUri="https://console.cloud.google.com/apis/credentials"
                       RequestNavigate="Hyperlink_RequestNavigate">
              Open Google Cloud Console ↗
            </Hyperlink>
          </TextBlock>
        </StackPanel>
      </Border>

      <TextBlock Text="Client ID" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="13" />
      <ui:TextBox x:Name="ClientIdBox"
                  PlaceholderText="xxxxxxxxxxxxxx.apps.googleusercontent.com"
                  Margin="0,0,0,14" />

      <TextBlock Text="Client Secret" FontWeight="SemiBold" Margin="0,0,0,4" FontSize="13" />
      <PasswordBox x:Name="ClientSecretBox"
                   PasswordChar="•"
                   Style="{StaticResource {x:Type PasswordBox}}"
                   Padding="8,6" FontSize="14" Margin="0,0,0,4" />
      <TextBlock FontSize="11" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}">
        Stored locally in your user profile — never sent anywhere except to Google.
      </TextBlock>

    </StackPanel>

    <!-- Footer buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
      <ui:Button Content="Cancel" Appearance="Secondary"
                 Click="Cancel_Click" Margin="0,0,8,0" />
      <ui:Button x:Name="ConnectBtn" Content="Connect →"
                 Icon="{ui:SymbolIcon Symbol=PlugConnected24}"
                 Click="Connect_Click" />
    </StackPanel>

  </Grid>
</Window>
