<Window x:Class="PropertyMatterHub.App.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Welcome to Wilson Daly Solicitors"
        Width="540" Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}">

  <Grid Margin="36,32,36,32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Margin="0,0,0,28">
      <TextBlock Text="Welcome 👋" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,6" />
      <TextBlock TextWrapping="Wrap" FontSize="13"
                 Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
        Let's get Wilson Daly Solicitors set up. You can change these settings later
        from the Settings screen.
      </TextBlock>
    </StackPanel>

    <!-- Fields -->
    <StackPanel Grid.Row="1" VerticalAlignment="Top">

      <TextBlock Text="Z: Drive Root Folder" FontWeight="SemiBold" Margin="0,0,0,4" />
      <TextBlock FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,6">
        The shared drive path where client folders are stored.
      </TextBlock>
      <ui:TextBox x:Name="ZDriveRootBox"
                  Text="{Binding ZDriveRoot, UpdateSourceTrigger=PropertyChanged}"
                  PlaceholderText="Z:\Clients" Margin="0,0,0,20" />

      <TextBlock Text="Excel Client Database" FontWeight="SemiBold" Margin="0,0,0,4" />
      <TextBlock FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,6">
        Path to the existing Excel spreadsheet (leave blank if not used).
      </TextBlock>
      <ui:TextBox Text="{Binding ExcelPath, UpdateSourceTrigger=PropertyChanged}"
                  PlaceholderText="Z:\ClientDatabase.xlsx" Margin="0,0,0,20" />

      <TextBlock Text="Google Workspace (optional)" FontWeight="SemiBold" Margin="0,0,0,4" />
      <TextBlock FontSize="12" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,0,0,10"
                 TextWrapping="Wrap">
        Place your <Bold>credentials.json</Bold> from Google Cloud Console at
        <Bold>Z:\PropertyMatterHub\credentials.json</Bold> then click Connect.
      </TextBlock>

      <Border Padding="12,10" CornerRadius="8"
              Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
              Margin="0,0,0,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="{Binding GoogleAuthStatus}" FontSize="13" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <ui:Button Content="Connect" Icon="{ui:SymbolIcon Symbol=PlugConnected24}"
                       Click="ConnectGoogle_Click"
                       Visibility="{Binding IsGoogleAuthorized, Converter={StaticResource InverseBoolToVisibility}}"
                       Appearance="Secondary" Margin="0,0,4,0" />
            <ui:ProgressRing Width="20" Height="20" IsIndeterminate="True"
                             Visibility="{Binding IsConnectingGoogle, Converter={StaticResource BoolToVisibility}}" />
            <ui:Badge Content="Connected" Appearance="Success"
                      Visibility="{Binding IsGoogleAuthorized, Converter={StaticResource BoolToVisibility}}" />
          </StackPanel>
        </Grid>
      </Border>

    </StackPanel>

    <!-- Footer buttons -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
      <TextBlock Text="You can change all of this in Settings later."
                 VerticalAlignment="Center" FontSize="11"
                 Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                 Margin="0,0,16,0" />
      <ui:Button Content="Get Started →" Icon="{ui:SymbolIcon Symbol=ArrowRight24}"
                 Click="GetStarted_Click" />
    </StackPanel>

  </Grid>
</Window>
