<UserControl x:Class="PropertyMatterHub.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="28,20,28,28">

      <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20" />

      <!-- Active matters summary -->
      <ui:CardExpander Header="Active Matters" Icon="{ui:SymbolIcon Symbol=Briefcase24}" IsExpanded="True" Margin="0,0,0,12">
        <ItemsControl ItemsSource="{Binding ActiveMatters}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,4" Padding="12,10" CornerRadius="8"
                      Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <ui:Badge Grid.Column="0" Content="{Binding MatterRef}" Margin="0,0,12,0" />
                  <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" Text="{Binding Client.Name}" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ui:CardExpander>

      <!-- Today's events -->
      <ui:CardExpander Header="Today's Events" Icon="{ui:SymbolIcon Symbol=CalendarToday24}" IsExpanded="True" Margin="0,0,0,12">
        <ItemsControl ItemsSource="{Binding TodaysEvents}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,4" Padding="12,10" CornerRadius="8"
                      Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <StackPanel>
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding StartUtc, StringFormat='HH:mm'}" FontSize="12"
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ui:CardExpander>

      <!-- Upcoming this week -->
      <ui:CardExpander Header="Upcoming This Week" Icon="{ui:SymbolIcon Symbol=Calendar24}" IsExpanded="True">
        <ItemsControl ItemsSource="{Binding UpcomingEvents}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,4" Padding="12,10" CornerRadius="8"
                      Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding StartUtc, StringFormat='ddd dd/MM'}" FontSize="12"
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ui:CardExpander>

    </StackPanel>
  </ScrollViewer>
</UserControl>
