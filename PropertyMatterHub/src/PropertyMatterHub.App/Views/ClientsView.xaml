<UserControl x:Class="PropertyMatterHub.App.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="340" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Client list -->
    <DockPanel Grid.Column="0">
      <StackPanel DockPanel.Dock="Top" Margin="16">
        <TextBlock Text="Clients" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
        <ui:Button Content="New Client" Icon="{ui:SymbolIcon Symbol=PersonAdd24}"
                   Command="{Binding NewClientCommand}" HorizontalAlignment="Stretch" />
      </StackPanel>
      <ListBox ItemsSource="{Binding Clients}"
               SelectedItem="{Binding SelectedClient}"
               BorderThickness="0" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,4">
              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
              <TextBlock Text="{Binding Email}" FontSize="12"
                         Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>

    <!-- Client edit form -->
    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="28,20,28,28"
                  Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
        <TextBlock Text="Client Details" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20" />

        <TextBlock Text="Name" FontSize="13" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding SelectedClient.Name, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Full name" Margin="0,0,0,12" />

        <TextBlock Text="Email" FontSize="13" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding SelectedClient.Email, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="email@example.com" Margin="0,0,0,12" />

        <TextBlock Text="Phone" FontSize="13" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding SelectedClient.Phone, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="087 123 4567" Margin="0,0,0,12" />

        <TextBlock Text="Address" FontSize="13" Margin="0,0,0,4" />
        <ui:TextBox Text="{Binding SelectedClient.Address, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Full address" AcceptsReturn="True" Height="80" Margin="0,0,0,20" />

        <StackPanel Orientation="Horizontal">
          <ui:Button Content="Save" Command="{Binding SaveClientCommand}"
                     Icon="{ui:SymbolIcon Symbol=Save24}" Margin="0,0,8,0" />
          <ui:Button Content="Cancel" Command="{Binding CancelCommand}"
                     Appearance="Secondary" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

  </Grid>
</UserControl>
