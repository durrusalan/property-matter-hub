<UserControl x:Class="PropertyMatterHub.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="28,20,28,28" MaxWidth="700" HorizontalAlignment="Left">

      <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,24" />

      <!-- Z: Drive section -->
      <TextBlock Text="Z: Drive Configuration" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

      <ui:CardControl Header="Z: Drive Root Path" Margin="0,0,0,10">
        <ui:TextBox Text="{Binding ZDriveRoot, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Z:\" Width="300" />
      </ui:CardControl>

      <ui:CardControl Header="Excel File Path" Margin="0,0,0,10">
        <ui:TextBox Text="{Binding ExcelPath, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Z:\ClientDatabase.xlsx" Width="300" />
      </ui:CardControl>

      <ui:CardControl Header="Case Folder Pattern (regex)" Margin="0,0,0,10">
        <StackPanel>
          <ui:TextBox Text="{Binding CaseFolderPattern, UpdateSourceTrigger=PropertyChanged}" Width="400" />
          <TextBlock Text="Named groups: ClientName, CaseNumber" FontSize="11"
                     Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
        </StackPanel>
      </ui:CardControl>

      <ui:CardControl Header="Case Folder Depth" Margin="0,0,0,10">
        <StackPanel Orientation="Horizontal">
          <ui:NumberBox Value="{Binding CaseFolderDepth}" Minimum="1" Maximum="5" Width="80" Margin="0,0,8,0" />
          <TextBlock Text="(1 = direct children, 2 = year/group folders)" FontSize="12"
                     Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
        </StackPanel>
      </ui:CardControl>

      <StackPanel Orientation="Horizontal" Margin="0,4,0,20">
        <ui:Button Content="Test Pattern Against Z: Drive" Icon="{ui:SymbolIcon Symbol=PlugConnected24}"
                   Command="{Binding TestPatternCommand}" Appearance="Secondary" />
      </StackPanel>

      <Border Padding="12,10" CornerRadius="8"
              Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
              Visibility="{Binding PatternTestResult, Converter={StaticResource StringToVisibility}}"
              Margin="0,0,0,20">
        <TextBlock Text="{Binding PatternTestResult}" />
      </Border>

      <!-- Z: Drive re-scan -->
      <TextBlock Text="Z: Drive Indexing" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

      <ui:CardControl Header="Import clients &amp; matters from Z: drive folders" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,10"
                     Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}">
            Scans Z:\Clients and creates a Client + Matter for each matched folder.
            Safe to run multiple times — existing records are never overwritten.
          </TextBlock>
          <StackPanel Orientation="Horizontal">
            <ui:Button Content="Re-scan Z: Drive" Icon="{ui:SymbolIcon Symbol=FolderSync24}"
                       Command="{Binding RescanZDriveCommand}" Margin="0,0,8,0" />
            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20"
                             Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVisibility}}" />
          </StackPanel>
          <Border Padding="10,8" CornerRadius="6" Margin="0,10,0,0"
                  Background="{ui:ThemeResource ControlFillColorDefaultBrush}"
                  Visibility="{Binding IndexingResult, Converter={StaticResource StringToVisibility}}">
            <TextBlock Text="{Binding IndexingResult}" TextWrapping="Wrap" FontSize="12" />
          </Border>
        </StackPanel>
      </ui:CardControl>

      <!-- Google section -->
      <TextBlock Text="Google Workspace" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

      <ui:CardControl Header="Gmail + Calendar Authentication" Margin="0,0,0,10">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <ui:Badge Content="Connected" Appearance="Success" Margin="0,0,8,0"
                      Visibility="{Binding IsGoogleAuthorized, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="{Binding GoogleAuthStatus}"
                       Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Orientation="Horizontal">
            <ui:Button Content="Connect Google Account" Icon="{ui:SymbolIcon Symbol=PlugConnected24}"
                       Command="{Binding ConnectGoogleCommand}" Appearance="Secondary"
                       Visibility="{Binding IsGoogleAuthorized, Converter={StaticResource InverseBoolToVisibility}}"
                       Margin="0,0,8,0" />
            <ui:Button Content="Disconnect" Icon="{ui:SymbolIcon Symbol=PlugDisconnected24}"
                       Command="{Binding DisconnectGoogleCommand}" Appearance="Caution"
                       Visibility="{Binding IsGoogleAuthorized, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,8,0" />
            <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20"
                             Visibility="{Binding IsConnectingGoogle, Converter={StaticResource BoolToVisibility}}" />
          </StackPanel>

          <TextBlock FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                     Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}">
            Requires credentials.json at Z:\PropertyMatterHub\credentials.json (from Google Cloud Console).
          </TextBlock>
        </StackPanel>
      </ui:CardControl>

      <!-- Save -->
      <ui:Button Content="Save Settings" Icon="{ui:SymbolIcon Symbol=Save24}"
                 Command="{Binding SaveCommand}" Margin="0,16,0,0" />

    </StackPanel>
  </ScrollViewer>
</UserControl>
