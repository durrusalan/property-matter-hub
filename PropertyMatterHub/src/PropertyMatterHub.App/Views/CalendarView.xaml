<UserControl x:Class="PropertyMatterHub.App.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:PropertyMatterHub.App.ViewModels">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="16,16,16,8">
      <TextBlock Text="Calendar" FontSize="20" FontWeight="SemiBold"
                 VerticalAlignment="Center" Margin="0,0,12,0" />
      <ui:Button Content="◀" Command="{Binding PreviousCommand}"
                 Appearance="Secondary" Margin="0,0,4,0" />
      <ui:Button Content="▶" Command="{Binding NextCommand}"
                 Appearance="Secondary" Margin="0,0,12,0" />
      <ui:Button Content="Month"  Command="{Binding SetViewModeCommand}"
                 CommandParameter="{x:Static vm:CalendarViewMode.Month}"
                 Appearance="Secondary" Margin="0,0,4,0" />
      <ui:Button Content="Week"   Command="{Binding SetViewModeCommand}"
                 CommandParameter="{x:Static vm:CalendarViewMode.Week}"
                 Appearance="Secondary" Margin="0,0,4,0" />
      <ui:Button Content="Agenda" Command="{Binding SetViewModeCommand}"
                 CommandParameter="{x:Static vm:CalendarViewMode.Agenda}"
                 Appearance="Secondary" Margin="0,0,12,0" />
      <ui:Button Content="+ Event" Icon="{ui:SymbolIcon Symbol=Add24}"
                 Command="{Binding NewEventCommand}" Margin="0,0,4,0" />
      <ui:Button Content="Sync"   Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                 Command="{Binding SyncCommand}" Appearance="Secondary" Margin="0,0,8,0" />
      <ui:ProgressRing Width="20" Height="20" IsIndeterminate="True" Margin="0,0,8,0"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />
      <TextBlock Text="{Binding SyncStatus}" VerticalAlignment="Center" FontSize="12"
                 Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
    </WrapPanel>

    <!-- ── Body: list or edit form ────────────────────────────────────────── -->
    <Grid Grid.Row="1">

      <!-- Agenda list (visible when not editing) -->
      <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
        <ItemsControl ItemsSource="{Binding Events}" Margin="16,0,16,16">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,4" Padding="14,12" CornerRadius="8"
                      Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <!-- Date / time -->
                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StartUtc, StringFormat='ddd dd/MM'}" FontSize="12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding StartUtc, StringFormat='HH:mm'}" FontSize="11"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                  </StackPanel>

                  <!-- Title + location -->
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Location}" FontSize="12"
                               Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{Binding Location, Converter={StaticResource StringToVisibility}}" />
                    <TextBlock FontSize="11" Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="{Binding Matter, Converter={StaticResource StringToVisibility}}">
                      <Run Text="📁 "/><Run Text="{Binding Matter.Title}" />
                    </TextBlock>
                  </StackPanel>

                  <!-- Sync badge + edit/delete -->
                  <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Badge Content="{Binding SyncStatus}" Margin="0,0,8,0" />
                    <ui:Button Icon="{ui:SymbolIcon Symbol=Edit24}" Appearance="Secondary"
                               ToolTip="Edit" Padding="4"
                               Command="{Binding DataContext.EditEventCommand,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                               CommandParameter="{Binding}" Margin="0,0,4,0" />
                    <ui:Button Icon="{ui:SymbolIcon Symbol=Delete24}" Appearance="Danger"
                               ToolTip="Delete" Padding="4"
                               Command="{Binding DataContext.DeleteEventCommand,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                               CommandParameter="{Binding}" />
                  </StackPanel>

                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Edit form (visible when editing) -->
      <ScrollViewer Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
        <StackPanel Margin="28,16,28,28" MaxWidth="640">
          <TextBlock Text="Event Details" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20" />

          <TextBlock Text="Title" FontSize="13" Margin="0,0,0,4" />
          <ui:TextBox Text="{Binding SelectedEvent.Title, UpdateSourceTrigger=PropertyChanged}"
                      PlaceholderText="Event title" Margin="0,0,0,14" />

          <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Start" FontSize="13" Margin="0,0,0,4" />
              <DatePicker SelectedDate="{Binding SelectedEvent.StartUtc}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="End" FontSize="13" Margin="0,0,0,4" />
              <DatePicker SelectedDate="{Binding SelectedEvent.EndUtc}" />
            </StackPanel>
          </Grid>

          <CheckBox Content="All-day event" IsChecked="{Binding SelectedEvent.IsAllDay}"
                    Margin="0,0,0,14" />

          <TextBlock Text="Location (optional)" FontSize="13" Margin="0,0,0,4" />
          <ui:TextBox Text="{Binding SelectedEvent.Location, UpdateSourceTrigger=PropertyChanged}"
                      PlaceholderText="e.g. Court Room 4" Margin="0,0,0,14" />

          <TextBlock Text="Description (optional)" FontSize="13" Margin="0,0,0,4" />
          <ui:TextBox Text="{Binding SelectedEvent.Description, UpdateSourceTrigger=PropertyChanged}"
                      PlaceholderText="Notes about this event…"
                      AcceptsReturn="True" Height="100" Margin="0,0,0,20" />

          <StackPanel Orientation="Horizontal">
            <ui:Button Content="Save"   Icon="{ui:SymbolIcon Symbol=Save24}"
                       Command="{Binding SaveEventCommand}" Margin="0,0,8,0" />
            <ui:Button Content="Cancel" Command="{Binding CancelEditCommand}"
                       Appearance="Secondary" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Grid>
</UserControl>
