<UserControl x:Class="PropertyMatterHub.App.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:PropertyMatterHub.App.ViewModels">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="16,16,16,8">
      <TextBlock Text="Calendar" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
      <ui:Button Content="◀" Command="{Binding PreviousCommand}" Appearance="Secondary" Margin="0,0,4,0" />
      <ui:Button Content="▶" Command="{Binding NextCommand}" Appearance="Secondary" Margin="0,0,12,0" />
      <ui:Button Content="Month"  Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static vm:CalendarViewMode.Month}"  Appearance="Secondary" Margin="0,0,4,0" />
      <ui:Button Content="Week"   Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static vm:CalendarViewMode.Week}"   Appearance="Secondary" Margin="0,0,4,0" />
      <ui:Button Content="Agenda" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static vm:CalendarViewMode.Agenda}" Appearance="Secondary" Margin="0,0,12,0" />
      <ui:Button Content="+ Event" Icon="{ui:SymbolIcon Symbol=Add24}" Command="{Binding NewEventCommand}" Margin="0,0,4,0" />
      <ui:Button Content="Sync" Icon="{ui:SymbolIcon Symbol=ArrowSync24}" Command="{Binding SyncCommand}" Appearance="Secondary" Margin="0,0,8,0" />
      <TextBlock Text="{Binding SyncStatus}" VerticalAlignment="Center" FontSize="12"
                 Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
    </WrapPanel>

    <!-- Agenda view (default) -->
    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{Binding Events}" Margin="16,0,16,16">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,4" Padding="14,12" CornerRadius="8"
                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="110" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding StartUtc, StringFormat='ddd dd/MM'}" FontSize="12"
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                  <TextBlock Text="{Binding StartUtc, StringFormat='HH:mm'}" FontSize="11"
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Location}" FontSize="12"
                             Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:Badge Grid.Column="2" Content="{Binding SyncStatus}" VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
