<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile: single self-contained .exe for Windows x64.
  Run with:
    dotnet publish src/PropertyMatterHub.App -p:PublishProfile=win-x64-singlefile
  Output lands in:
    src/PropertyMatterHub.App/publish/
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>AnyCPU</Platform>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\..\publish\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishReadyToRun>false</PublishReadyToRun>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Trim unused assemblies to keep exe size down (safe for this app). -->
    <PublishTrimmed>false</PublishTrimmed>
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>
</Project>
